# DermaLens Backend Configuration
# Copy this to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8000

# Model
# Path to your custom YOLOv11 weights (.pt file)
# If not set or file doesn't exist, falls back to yolo11n.pt pretrained weights
MODEL_PATH=models/dermalens.pt

# Confidence threshold for detections (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.25

# Maximum image size in pixels (width or height)
MAX_IMAGE_SIZE=1280
